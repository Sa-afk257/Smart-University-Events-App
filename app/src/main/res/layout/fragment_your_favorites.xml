<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="match_parent" android:padding="8dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Your Favorites" android:textAppearance="?attr/textAppearanceHeadline5"
        android:layout_margin="8dp"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/favorites_recycler_view" android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <TextView android:id="@+id/no_favorites_text" android:layout_width="match_parent"
        android:layout_height="match_parent" android:text="You have no favorite events."
        android:gravity="center" android:visibility="gone"/>
</LinearLayout>
